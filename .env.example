# GitHub OAuth App credentials (server-only — never expose to the client)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Random long string used to sign/verify the OAuth state cookie
OAUTH_STATE_SECRET=

# Template repos, each "owner/name". Owner is YOUR account (holds the templates).
# Learner repos are still created under the LEARNER's account (from her OAuth login).
FRONTEND_TEMPLATE=your-username/fullstack-ai-journey-template
BI_TEMPLATE=your-username/ai-engineering-journey-template

# Optional: pin the OAuth callback. Otherwise derived from the request origin
# (works for localhost + prod). Must match the GitHub OAuth App callback URL.
# OAUTH_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback
